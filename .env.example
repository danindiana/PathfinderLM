# PathfinderLM environment configuration
# Copy to `.env` and edit. NEVER commit your real .env file.

# --- Flask ---
FLASK_ENV=production          # development | production
FLASK_PORT=5000
SECRET_KEY=change-me-in-production

# --- Models (local-first via Ollama) ---
LLM_PROVIDER=ollama           # ollama | openai
OLLAMA_HOST=http://ollama:11434   # use http://localhost:11434 outside Docker
MODEL_NAME=deepseek-r1:14b    # generation model; set to pathfinder-coach after `make model`
EMBEDDING_MODEL=nomic-embed-text  # local Ollama embedding model for FAISS
DEVICE=auto                   # cpu | cuda | auto
# SYSTEM_PROMPT=              # override the coaching persona (system role); see Modelfile

# --- Optional cloud fallback (only used when LLM_PROVIDER=openai) ---
# OPENAI_API_KEY=

# --- OpenClaw agent layer (optional, https://openclaw.ai) ---
# OpenClaw runs on the host and can point at the same Ollama endpoint above.
# OPENCLAW_ENABLED=false

# --- RAG / Retrieval ---
FAISS_INDEX_PATH=results/faiss.index
KNOWLEDGE_BASE_DIR=data/processed
TOP_K=5

# --- Data store (optional, for user data) ---
# DATABASE_URL=postgresql://user:password@localhost:5432/pathfinderlm
# REDIS_URL=redis://localhost:6379/0

# --- Logging / Monitoring ---
LOG_LEVEL=INFO
PROMETHEUS_PORT=9090

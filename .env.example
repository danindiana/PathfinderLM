# PathfinderLM environment configuration
# Copy to `.env` and edit. NEVER commit your real .env file.

# --- Flask ---
FLASK_ENV=production          # development | production
FLASK_PORT=5000
SECRET_KEY=change-me-in-production

# --- Models ---
MODEL_NAME=bert-base-uncased
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
DEVICE=auto                   # cpu | cuda | auto

# --- RAG / Retrieval ---
FAISS_INDEX_PATH=results/faiss.index
KNOWLEDGE_BASE_DIR=data/processed
TOP_K=5

# --- Data store (optional, for user data) ---
# DATABASE_URL=postgresql://user:password@localhost:5432/pathfinderlm
# REDIS_URL=redis://localhost:6379/0

# --- Logging / Monitoring ---
LOG_LEVEL=INFO
PROMETHEUS_PORT=9090
